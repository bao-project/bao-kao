; --------------------------------------------------------------------------------
; @Title: Demo script for TC4D9XE on TriBoard-TC4x9-COM (Flash, sieve app)
; @Description:
;   Programs the sieve demo application (single-core) into the processor
;   internal flash and sets up a demo debug scenario. This script can be used
;   as a template for flashing an application.
; @Keywords: flash, Infineon, TC4xx, TriCore
; @Author: HDA, MEI
; @Board: TriBoard-TC4x9-COM
; @Chip: TC4D9XE
; @Copyright: (C) 1989-2024 Lauterbach GmbH, licensed for use with TRACE32(R) only
; --------------------------------------------------------------------------------
; $Id: demo_flash.cmm 22929 2024-06-14 11:19:14Z meick $


LOCAL &ToolsDir
&ToolsDir="~~/demo/tricore/hardware/tools/tc4x"

; --------------------------------------------------------------------------------
; initialize and start the debugger
;RESet

SYStem.CPU TC4D7XP

CORE.ASSIGN 1. 2. 3. 4. 5. 6.  // assign cores to the SMP system

; disable serial trace until it is configured
IF Analyzer()
  Analyzer.DISable
SYStem.Up

; --------------------------------------------------------------------------------
; Check PreRequisites
GOSUB CheckPreRequisites

; -----------------------------------------------------+----------------------------
; optional settings:
SYStem.Option DUALPORT ON
SETUP.Var %SpotLight
MAP.BOnchip 0x0--0xffffffff // force onchip-breakpoints

; --------------------------------------------------------------------------------
; Flash programming
LOCAL &elfFile &progFlash &bmhdResult

LOCAL &bao_elf &baremetal_elf


;&bao_elf="/home/mafs/MISRA/bao-hypervisor/bin/tc4dx/baremetal/bao.elf"
&bao_elf="/home/mafs/MISRA/bao-hypervisor/bin/tc4dx/cs/bao.elf"
;&baremetal_elf="/home/mafs/MISRA/bins/hv.elf"
&baremetal_elf="/home/mafs/MISRA/bao-baremetal-guest/build/tc4dx/baremetal.elf"
&baremetal_elf2="/home/mafs/MISRA/bins/baremetal2.elf"

;&bao_elf="/home/mafs/MISRA/bao-hypervisor/bin/tc4dx/ipc/bao.elf"
;&baremetal_elf1="/home/mafs/MISRA/bins/baremetal7.elf"
;&baremetal_elf2="/home/mafs/MISRA/bins/baremetal6.elf"
;&bao_elf="/home/mafs/bao-demos/wrkdir/srcs/bao/bin/tc4dx/baremetal/bao.elf"
;&baremetal_elf="/home/mafs/bao-demos/wrkdir/srcs/baremetal/build/tc4dx/baremetal.elf"
&elfFile="&bao_elf"
;&elfFile="/home/mafs/bao-tricore/bin/tc49/baremetal/bao.elf"
;&elfFile="/home/mafs/MISRA/bao-hypervisor/bin/tc4dx/baremetal/bao.elf"

; prepare flash programming (declarations)
DO ~~/demo/tricore/flash/tc4dx.cmm CPU=TC4D9XE PREPARE_HOST

; check if application is already in flash and load symbols
Data.LOAD.Elf "&elfFile" /DIFF /SingleLineAdjacent

IF FOUND()
(
  DIALOG.YESNO "Program Bao into flash memory?"
  ENTRY &progFlash
  &progFlash=TRUE()
)
ELSE
(
  &progFlash=TRUE()
  ; start program execution
  ;b.set 0xA0000000 /Onchip
  ;b.set 0x90080000 /Onchip
  ;Go.direct main
)
IF (&progFlash)
(
  ; ==== Step 0: Initialize DSPR/PSPR ====

  DO &ToolsDir/meminit_host.cmm "CPU*"
  DO &ToolsDir/meminit_host.cmm "LMU*"
  ;DO &ToolsDir/meminit_host.cmm "CPU1*"
  ;DO &ToolsDir/meminit_host.cmm "CPU0.PSPR"
  ;DO &ToolsDir/meminit_host.cmm "CPU0.DSPR"

  ;DO &ToolsDir/meminit_host.cmm "CPU1.PSPR"
  ;DO &ToolsDir/meminit_host.cmm "CPU1.DSPR"

  ; ==== Step 1: Program TriCore code ====

  ; enable flash programming
  FLASH.ReProgram ALL

  ; load demo application
  Data.LOAD.Elf "&elfFile"

  ;Data.LOAD.Elf "/home/mafs/bao-tricore/bin/tc49/baremetal-dual/bao.elf" /NoClear
  ;load guest?

  FLASH.ReProgram OFF

  ; ==== Step 2: Write boot mode header ====

  PRIVATE &progUcb &ucbDiff &supported &diffAddress &DMU_GP_HOST_CONFIRMA &result
  &progUcb=TRUE()
  ; Check if UCB is in state UNLOCKED. Other states are not supported by this script
  &DMU_GP_HOST_CONFIRMA=Data.Long(ANC:0xF8040530)
  &supported=(((&DMU_GP_HOST_CONFIRMA)&(0x00030000))==0x00010000)

  IF !&supported
  (
    DIALOG.MESSAGE "UCB_RTC_BMHD0 is not in state unlocked or unread"
  )

  ; Check if we need to program the BMHD
  &ucbDiff=FALSE()

  IF &supported
  (
    Data.LOAD.Elf "&elfFile" ANC:0xAE404800++0x7FF /DIFF
    &ucbDiff=FOUND()
  )

  IF (&ucbDiff)
  (
    DIALOG.YESNO "Configure UCB_RTC_BMHD0 to start demo application?"
    ENTRY &progUcb
  )

  IF (&progUcb)
  (
    ; programming UCB_RTC_BMHD0
    IF (&ucbDiff)
    (
      ; activate UCB_RTC_BMHD0 modification
      DO ~~/demo/tricore/flash/tc4x-ucb.cmm UCB=UCB_RTC_BMHD0 ACTIVATE

      ; load data of UCB_RTC_BMHD0
      Data.LOAD.Elf "&elfFile" ANC:0xAE404800++0x7FF

      ; Perform a formal verification of the UCB_RTC_BMHD0 content.
      ; If the content is formally correct then program the changes to the device.
      ; If the check detected invalid content the flash programming is aborted.
      ; In any case NOP protection is restored for UCB_RTC_BMHD0 range.
      DO ~~/demo/tricore/flash/tc4x-ucb.cmm UCB=UCB_RTC_BMHD0 PROGRAM
      ENTRY &result

      IF ("&result"!="UCBOK")
        ENDDO

      Data.LOAD.Elf "&elfFile" ANC:0xAE404800++0x7FF /DIFF
      IF FOUND()
      (
        &diffAddress=TRACK.ADDRESS()
        DIALOG.MESSAGE "File &elfFile has not been fully flashed, difference found at address &diffAddress (BMHD0_COPY)"
        ENDDO
      )
    )
  )
  ; ==== Step 3: Verify programming ====

  Data.LOAD.Elf "&elfFile" /DIFF
  IF FOUND()
  (
    ; maybe some sections are still declared as NOP?
    &diffAddress=TRACK.ADDRESS()
    DIALOG.MESSAGE "File &elfFile has not been fully flashed, difference found at address &diffAddress (check flash declaration)"
  )
)
; --------------------------------------------------------------------------------
; configure USR access to read 64-bit STM registers
Data.USRACCESS 0xC0000000 0xD0000000 1024. ~~/demo/tricore/etc/usraccess/usraccess.gnu.bin
; start program execution

;Data.LOAD.Elf "/home/mafs/TRICORE/bao-baremetal-guest/bins/baremetal7.elf" /NoCode /NoClear
;Data.LOAD.Elf "/home/mafs/TRICORE/bao-baremetal-guest/bins/baremetal6.elf" /NoCode /NoClear

Data.LOAD.Elf &baremetal_elf /NoCode /NoClear
Data.LOAD.Elf &baremetal_elf2 /NoCode /NoClear
sYmbol.SourcePATH.Translate "C:\Users\afomm\AURIX-v1.10.24-workspace/hv" "/home/mafs/Downloads/hv"

;Data.LOAD.Elf &baremetal_elf1 /NoCode /NoClear
;Data.LOAD.Elf &baremetal_elf2 /NoCode /NoClear
;Data.LOAD.Elf "/home/mafs/MISRA/freertos-over-bao/build/tc49/freertos.elf" /NoCode /NoClear

break.set 0xA0000000 /Onchip /CORE 0
break.set mpu_data_entry_allocate  /Onchip /Core 0


;Var.AddWatch (struct cpu *)0x90009FC0
;Var.AddWatch (struct cpu *)0x9000BBC0
;Var.AddWatch (struct cpu *)0x9000D7C0
;Var.AddWatch (struct cpu *)0x9000F3C0
;Var.AddWatch (struct cpu *)0x90010FC0
;Var.AddWatch (struct cpu *)0x90012BC0



;break.set init_dlmus /Onchip
;break.set vcpu_arch_entry /Onchip


;Go.direct main
; --------------------------------------------------------------------------------

ENDDO



SUBROUTINE CheckPreRequisites
(
  PRIVATE &result

  IF SYStem.Mode()<5.
  (
    PRINT %ERROR "The communication with the CPU is not established"
    ENDDO
  )
  ; Check CSRM boot mode
  DO &ToolsDir/check_demo_config.cmm CSRMCFG_is_Default
  ENTRY &result
  IF !&result
    ENDDO

  ; Check Boot Mode Lock
  DO &ToolsDir/check_demo_config.cmm BML_is_Default
  ENTRY &result
  IF !&result
    ENDDO
)
